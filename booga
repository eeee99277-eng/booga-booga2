-- Special handling for "essence" which needs to exclude certain types
local function checkEssence(name)
    if name:find("essence") and not name:find("void") and not name:find("chief") then
        return "pickupEssence"
    end
    return nil
end

RunService.Heartbeat:Connect(function()
    -- Check if any pickup is enabled (optimized with early exit)
    local anyOn = states.pickupKeys or states.pickupRaw or states.pickupRawFish or
                  states.pickupCookedFish or states.pickupGold or states.pickupIron or
                  states.pickupEssence or states.pickupVoidEssence or states.pickupChiefEssence or
                  states.pickupPinkDiamond or states.pickupCrystal or states.pickupMoltenBow or
                  states.pickupMoltenShield or states.pickupStrangeGreatsword or states.pickupStrangeBag or
                  states.pickupAncientHammer or states.pickupSpiritKey or states.pickupOldKey or
                  states.pickupStrangeKey or states.pickupGodHalo or states.pickupGodChestplate or
                  states.pickupGodLeggings or states.pickupGodPickaxe or states.pickupGodAxe or
                  states.pickupGodRock or states.pickupGodRod or states.pickupGodBag or
                  states.pickupGodSailboat or states.pickupGodHut or states.pickupGem or
                  states.pickupWood or states.pickupSilverCoins or states.pickupGoldCoins or
                  states.pickupRawMorsel or states.pickupLeaves or states.pickupBananas or
                  states.pickupBloodfruit or states.pickupEgg or states.pickupStardust or
                  states.pickupCookedMeat or states.pickupArrows or states.pickupDock or
                  states.pickupNest or states.pickupBag
    
    if not anyOn then return end
    
    -- Reduced throttle from 0.12s to 0.05s for faster pickup
    local now = os.clock()
    if now - lastPickup < 0.05 then return end
    lastPickup = now
    
    local ch = player.Character
    if not ch then return end
    local root = ch:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    -- Use GetChildren() instead of GetDescendants() for better performance
    for _, item in ipairs(itemsFolder:GetChildren()) do
        if processed[item] then continue end
        
        local lower = item.Name:lower()
        
        -- O(1) hash lookup instead of iterating through all matchers
        local pickupKey = pickupLookup[lower]
        
        -- Special case for essence
        if not pickupKey then
            pickupKey = checkEssence(lower)
        end
        
        if pickupKey and states[pickupKey] then
            local p = item.PrimaryPart or item:FindFirstChildWhichIsA("BasePart")
            if p then
                local dist = (root.Position - p.Position).Magnitude
                if dist <= pickupRadii[pickupKey] then
                    -- Use concurrent execution for multiple pickups
                    task.spawn(function()
                        pcall(function() PickupItem:InvokeServer(item) end)
                    end)
                    processed[item] = true
                    task.delay(2, function() processed[item] = nil end)
                end
            end
        end
    end
end)

