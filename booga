-- ── REMOTE SPY ────────────────────────────────────────────
local spyActionId      = nil
local spyArmed         = false
local alwaysSpyPlant   = false
local calibStatLbl     = nil

local ovenSpyActionId  = nil
local ovenSpyArmed     = false
local alwaysSpyOven    = false
local ovenCalibStatLbl = nil

local hookAvailable = (typeof(hookmetamethod) == "function") and (typeof(getnamecallmethod) == "function")

if hookAvailable then
    pcall(function()
        local oldNamecall
        oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
            local ok, method = pcall(getnamecallmethod)
            if ok and (method == "InvokeServer" or method == "FireServer") then
                if self == StructInput then
                    local args = {...}
                    local inst  = typeof(args[1]) == "Instance" and args[1]
                    local actId = typeof(args[2]) == "number"   and args[2]

                    if inst and actId and inst.Name == "Plant Box" then
                        if spyArmed or alwaysSpyPlant then
                            if actId ~= spyActionId then
                                spyActionId = actId
                                print(("[BoogaHub] Plant ID updated: %d"):format(spyActionId))
                                if calibStatLbl then
                                    calibStatLbl.Text       = "🔄 ID: " .. spyActionId
                                    calibStatLbl.TextColor3 = Color3.fromRGB(52,211,153)
                                end
                            end
                            if spyArmed then
                                spyArmed      = false
                                alwaysSpyPlant = true
                                if calibStatLbl then
                                    calibStatLbl.Text       = "✅ ID: " .. spyActionId
                                    calibStatLbl.TextColor3 = Color3.fromRGB(52,211,153)
                                end
                            end
                        end
                    end

                    if inst and actId then
                        local nm = inst.Name:lower()
                        if nm:find("oven") or nm:find("furnace") or nm:find("stove") then
                            if ovenSpyArmed or alwaysSpyOven then
                                if actId ~= ovenSpyActionId then
                                    ovenSpyActionId = actId
                                    print(("[BoogaHub] Oven ID updated: %d"):format(ovenSpyActionId))
                                    if ovenCalibStatLbl then
                                        ovenCalibStatLbl.Text       = "🔄 ID: " .. ovenSpyActionId
                                        ovenCalibStatLbl.TextColor3 = Color3.fromRGB(52,211,153)
                                    end
                                end
                                if ovenSpyArmed then
                                    ovenSpyArmed  = false
                                    alwaysSpyOven  = true
                                    if ovenCalibStatLbl then
                                        ovenCalibStatLbl.Text       = "✅ ID: " .. ovenSpyActionId
                                        ovenCalibStatLbl.TextColor3 = Color3.fromRGB(52,211,153)
                                    end
                                end
                            end
                        end
                    end
                end
            end
            return oldNamecall(self, ...)
        end)
    end)
else
    warn("[BoogaHub] hookmetamethod unavailable — use manual ID entry below.")
end

