    local bs=Instance.new("UIStroke",box) bs.Color=C.border bs.Thickness=1
    box.FocusLost:Connect(function()
        local v=tonumber(box.Text)
        if v then pickupRadii[radiusKey]=math.clamp(v,1,999)
        else box.Text=tostring(pickupRadii[radiusKey]) end
    end)

    local pill=Instance.new("Frame",row)
    pill.Size=UDim2.new(0,40,0,22) pill.Position=UDim2.new(1,-52,0.5,-11)
    pill.BackgroundColor3=C.pill_of pill.BorderSizePixel=0
    Instance.new("UICorner",pill).CornerRadius=UDim.new(1,0)

    local knob=Instance.new("Frame",pill)
    knob.Size=UDim2.new(0,16,0,16) knob.Position=UDim2.new(0,3,0.5,-8)
    knob.BackgroundColor3=C.knob knob.BorderSizePixel=0
    Instance.new("UICorner",knob).CornerRadius=UDim.new(1,0)

    local function setV(on)
        TweenService:Create(pill,TweenInfo.new(0.15),{BackgroundColor3=on and C.pill_on or C.pill_of}):Play()
        TweenService:Create(knob,TweenInfo.new(0.15),{
            BackgroundColor3=on and C.white or C.knob,
            Position=on and UDim2.new(1,-19,0.5,-8) or UDim2.new(0,3,0.5,-8)
        }):Play()
        TweenService:Create(stroke,TweenInfo.new(0.15),{Color=on and C.accent or C.border}):Play()
        TweenService:Create(lbl,TweenInfo.new(0.15),{TextColor3=on and C.white or C.muted}):Play()
    end

    local btn=Instance.new("TextButton",row)
    btn.Size=UDim2.new(1,0,1,0) btn.BackgroundTransparency=1 btn.Text=""
    btn.MouseButton1Click:Connect(function()
        states[stateKey]=not states[stateKey]
        setV(states[stateKey])
    end)
end

