-- ── AUTO CRAFT ────────────────────────────────────────────
local craftThread, isCrafting = nil, false
local function runAutoCraft()
    isCrafting = true
    while states.autoCraftHut or states.autoCraftArrow or states.autoCraftAnvil do
        if states.autoCraftHut then
            pcall(function() CraftItem:InvokeServer("Big Ol' Hut", craftQtys.autoCraftHut) end)
            task.wait(0.15)
        end
        if states.autoCraftArrow then
            pcall(function() CraftItem:InvokeServer("Arrow", craftQtys.autoCraftArrow) end)
            task.wait(0.15)
        end
        if states.autoCraftAnvil then
            pcall(function() CraftItem:InvokeServer("Anvil", craftQtys.autoCraftAnvil) end)
            task.wait(0.15)
        end
        task.wait(0.1)
    end
    isCrafting = false
end
local function startAutoCraft()
    if isCrafting then return end
    craftThread = task.spawn(runAutoCraft)
end
local function stopAutoCraft()
    if states.autoCraftHut or states.autoCraftArrow or states.autoCraftAnvil then return end
    if craftThread then task.cancel(craftThread) end
    craftThread = nil isCrafting = false
end

-- ── AUTO ATTACK ───────────────────────────────────────────
local atkThread
local function isBarbarian(m) return m and m.Name:find("Barbarian") end
local function nearestBarb()
    local ch = player.Character if not ch then return end
    local root = ch:FindFirstChild("HumanoidRootPart") if not root then return end
    local best, bestD = nil, ATTACK_RANGE+5
    for _, c in ipairs(crittersFdr:GetDescendants()) do
        if c:IsA("Model") and isBarbarian(c) then
            local r = c:FindFirstChild("HumanoidRootPart") or c:FindFirstChildWhichIsA("BasePart")
            if r then
                local d = (root.Position-r.Position).Magnitude
                if d <= ATTACK_RANGE and d < bestD then bestD=d best=c end
            end
        end
    end
    return best
end
local function startAutoAttack()
    if atkThread then return end
    atkThread = task.spawn(function()
        while states.autoAttack do
            if nearestBarb() then
                pressKey(slotKeys[1]) task.wait(0.08)
                while states.autoAttack and nearestBarb() do
                    if not isMouseOverGUI() then leftClick() end
                    task.wait(1/CLICK_CPS)
                end
            else task.wait(0.2) end
        end atkThread = nil
    end)
end
local function stopAutoAttack()
    if atkThread then task.cancel(atkThread) end atkThread = nil
end

