--  OVEN HELPERS (Optimized with caching)
-- ══════════════════════════════════════════════════════════
local cachedOvens  = {}
local lastOvenScan = 0

local function getNearbyOvens()
    local ch = player.Character
    if not ch then return {} end
    local root = ch:FindFirstChild("HumanoidRootPart")
    if not root then return {} end
    local out, seen = {}, {}
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and not seen[obj] then
            local n = obj.Name:lower()
            if n:find("oven") or n:find("furnace") or n:find("stove") then
                local part = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
                if part then
                    local d = (root.Position - part.Position).Magnitude
                    if d <= OVEN_RADIUS then
                        seen[obj] = true
                        table.insert(out, {model=obj, part=part, dist=d})
                    end
                end
            end
        end
    end
    table.sort(out, function(a,b) return a.dist < b.dist end)
    return out
end

local function getCachedOvens()
    local now = os.clock()
    if now - lastOvenScan > 1 then  -- Reduced from 2s to 1s for faster updates
        cachedOvens  = getNearbyOvens()
        lastOvenScan = now
    end
    return cachedOvens
end

-- ══════════════════════════════════════════════════════════
--  AUTO COOK FISH (Optimized with concurrent execution)
-- ══════════════════════════════════════════════════════════
local cookThread, isCooking = nil, false

local function runAutoCook()
    isCooking = true
    while states.autoCookFish do
        local ch = player.Character
        if not ch or not ch:FindFirstChild("HumanoidRootPart") then task.wait(0.02) continue end
        if not ovenSpyActionId then task.wait(0.05) continue end

        local ovens = getNearbyOvens()
        cachedOvens  = ovens
        lastOvenScan = os.clock()

        if #ovens == 0 then task.wait(0.05) continue end

        -- Process all ovens concurrently for maximum speed
        local threads = {}
        for _, od in ipairs(ovens) do
            if not states.autoCookFish then break end
            threads[#threads + 1] = task.spawn(function()
                for i = 1, FISH_PER_OVEN do
                    if not states.autoCookFish then break end
                    pcall(function()
                        StructInput:InvokeServer(od.model, ovenSpyActionId)
                    end)
                    task.wait(0.002)  -- Reduced from 0.002
                end
            end)
        end
        
        -- Wait for all threads to complete
        for _, t in ipairs(threads) do
            task.wait()
        end
        
        task.wait(0.05)  -- Reduced from 0.05
    end
    isCooking = false
end

local function startAutoCook()
    if isCooking then return end
    cookThread = task.spawn(runAutoCook)
end
local function stopAutoCook()
    states.autoCookFish = false
    if cookThread then task.cancel(cookThread) end
    cookThread = nil isCooking = false
end

-- ══════════════════════════════════════════════════════════
--  AUTO PLANT (Optimized with concurrent execution)
-- ══════════════════════════════════════════════════════════
local plantThread, isPlanting = nil, false
local plantRadius = PLANT_RADIUS

local function getNearbyPlantBoxes()
    if not buildsFolder then return {} end
    local ch = player.Character
    if not ch then return {} end
    local root = ch:FindFirstChild("HumanoidRootPart")
    if not root then return {} end
    local out = {}
    for _, obj in ipairs(buildsFolder:GetChildren()) do
        if obj.Name == "Plant Box" and obj:IsA("Model") then
            local part = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
            if part then
                local d = (root.Position - part.Position).Magnitude
                if d <= plantRadius then
                    table.insert(out, {obj=obj, dist=d})
                end
            end
        end
    end
    table.sort(out, function(a,b) return a.dist < b.dist end)
    return out
end

local function runAutoPlant()
    isPlanting = true
    while states.autoPlant do
        local ch = player.Character
        if not ch or not ch:FindFirstChild("HumanoidRootPart") then task.wait(0.05) continue end
        if not spyActionId then task.wait(0.05) continue end
        local boxes = getNearbyPlantBoxes()
        if #boxes == 0 then task.wait(0.05) continue end
        
        -- Process all boxes concurrently
        local threads = {}
        for _, b in ipairs(boxes) do
            if not states.autoPlant then break end
            threads[#threads + 1] = task.spawn(function()
                pcall(function()
                    StructInput:InvokeServer(b.obj, spyActionId)
                end)
            end)
        end
        
        for _, t in ipairs(threads) do
            task.wait()
        end
        
        task.wait(0.02)  -- Reduced from 0.01 between loops
    end
    isPlanting = false
end

local function startAutoPlant()
    if isPlanting then return end
    plantThread = task.spawn(runAutoPlant)
end
local function stopAutoPlant()
    states.autoPlant = false
    if plantThread then task.cancel(plantThread) end
    plantThread = nil isPlanting = false
end

