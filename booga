-- ── GUI PROTECTION ─────────────────────────────────────────
local guiFrame
local function isMouseOverGUI()
    if not guiFrame or not guiFrame.Visible then return false end
    local m   = player:GetMouse()
    local pos = guiFrame.AbsolutePosition
    local sz  = guiFrame.AbsoluteSize
    local pad = 80
    return m.X >= pos.X-pad and m.X <= pos.X+sz.X+pad
       and m.Y >= pos.Y-pad and m.Y <= pos.Y+sz.Y+pad
end

-- ── OVEN COOK ──────────────────────────────────────────────
local cookThread, isCooking = nil, false
local calibFX, calibFY

local function getFishPos()
    if calibFX then return calibFX, calibFY end
    local vp = workspace.CurrentCamera.ViewportSize
    return math.floor(vp.X*.5), math.floor(vp.Y*.3)
end

local function isOvenGuiOpen()
    for _,gui in ipairs(playerGui:GetChildren()) do
        if gui.Name=="BoogaHub" or not gui.Enabled then continue end
        for _,d in ipairs(gui:GetDescendants()) do
            if (d:IsA("TextLabel") or d:IsA("TextButton")) and d.Visible then
                if d.Text:lower():find("oven") then return true end
            end
        end
    end
    return false
end

local function waitOven(t)
    local dl = os.clock()+t
    while os.clock()<dl do
        if isOvenGuiOpen() then return true end
        task.wait(0.02)
    end
    return false
end

local function getNearbyOvens()
    local ch = player.Character
    if not ch then return {} end
    local root = ch:FindFirstChild("HumanoidRootPart")
    if not root then return {} end
    local out,seen = {},{}
    for _,obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and not seen[obj] then
            local n = obj.Name:lower()
            if n:find("oven") or n:find("furnace") or n:find("stove") then
                local part = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
                if part then
                    local d = (root.Position-part.Position).Magnitude
                    if d <= OVEN_RADIUS then
                        seen[obj]=true
                        table.insert(out,{model=obj,part=part,dist=d})
                    end
                end
            end
        end
    end
    table.sort(out,function(a,b) return a.dist<b.dist end)
    return out
end

local function clickFishNTimes(x, y)
    if isMouseOverGUI() then return end
    VirtualInputManager:SendMouseMoveEvent(x, y, game)
    task.wait(0.03)
    for i = 1, FISH_PER_OVEN do
        if isMouseOverGUI() then break end
        VirtualInputManager:SendMouseButtonEvent(x,y,0,true, game,0)
        task.wait(0.015)
        VirtualInputManager:SendMouseButtonEvent(x,y,0,false,game,0)
        task.wait(0.015)
    end
end

local function runAutoCook()
    isCooking = true
    local filled = {}

    while states.autoCookFish do
        local ch = player.Character
        if not ch or not ch:FindFirstChild("HumanoidRootPart") then task.wait(0.3) continue end

        local ovens = getNearbyOvens()
        if #ovens == 0 then
            filled = {}
            task.wait(0.3)
            continue
        end

        local queue = {}
        for _, o in ipairs(ovens) do
            if not filled[o.model] then
                table.insert(queue, o)
            end
        end

        if #queue == 0 then
            filled = {}
            continue
        end

        local cam = workspace.CurrentCamera

        for _, od in ipairs(queue) do
            if not states.autoCookFish then break end

            local sp, vis = cam:WorldToScreenPoint(od.part.Position)
            if not vis then continue end
            local ox, oy = math.floor(sp.X), math.floor(sp.Y)

            VirtualInputManager:SendMouseMoveEvent(ox, oy, game)
            task.wait(0.06)
            VirtualInputManager:SendMouseButtonEvent(ox, oy, 0, true,  game, 0)
            task.wait(0.04)
            VirtualInputManager:SendMouseButtonEvent(ox, oy, 0, false, game, 0)

            if waitOven(1.5) then
                task.wait(0.04)
                local fx, fy = getFishPos()
                clickFishNTimes(fx, fy)
                filled[od.model] = true
                task.wait(0.03)
                pressKey(Enum.KeyCode.E)
                task.wait(0.06)
            else
                filled[od.model] = true
                pressKey(Enum.KeyCode.E)
                task.wait(0.05)
            end
        end
    end
    isCooking = false
end

local function startAutoCook()
    if isCooking then return end
    cookThread = task.spawn(runAutoCook)
end
local function stopAutoCook()
    states.autoCookFish=false
    if cookThread then task.cancel(cookThread) end
    cookThread=nil isCooking=false
end

-- ── AUTO ATTACK ────────────────────────────────────────────
local atkThread
local function isBarbarian(m) return m and m.Name:find("Barbarian") end
local function nearestBarb()
    local ch = player.Character if not ch then return end
    local root = ch:FindFirstChild("HumanoidRootPart") if not root then return end
    local best,bestD = nil, ATTACK_RANGE+5
    for _,c in ipairs(crittersFdr:GetDescendants()) do
        if c:IsA("Model") and isBarbarian(c) then
            local r = c:FindFirstChild("HumanoidRootPart") or c:FindFirstChildWhichIsA("BasePart")
            if r then
                local d=(root.Position-r.Position).Magnitude
                if d<=ATTACK_RANGE and d<bestD then bestD=d best=c end
            end
        end
    end
    return best
end
local function startAutoAttack()
    if atkThread then return end
    atkThread = task.spawn(function()
        while states.autoAttack do
            if nearestBarb() then
                pressKey(slotKeys[1]) task.wait(0.08)
                while states.autoAttack and nearestBarb() do
                    if not isMouseOverGUI() then leftClick() end
                    task.wait(1/CLICK_CPS)
                end
            else task.wait(0.2) end
        end atkThread=nil
    end)
end
local function stopAutoAttack()
    if atkThread then task.cancel(atkThread) end atkThread=nil
end

