RunService.Heartbeat:Connect(function()
    local anyOn=false
    for _,m in ipairs(matchers) do if states[m.k] then anyOn=true break end end
    if not anyOn then return end
    local now=os.clock()
    if now-lastPickup<0.12 then return end
    lastPickup=now
    local ch=player.Character if not ch then return end
    local root=ch:FindFirstChild("HumanoidRootPart") if not root then return end
    for _,item in ipairs(itemsFolder:GetChildren()) do
        if processed[item] then continue end
        local lower=item.Name:lower()
        for _,m in ipairs(matchers) do
            if states[m.k] and m.f(lower) then
                local p=item.PrimaryPart or item:FindFirstChildWhichIsA("BasePart")
                if p and (root.Position-p.Position).Magnitude<=pickupRadii[m.k] then
                    pcall(function() PickupItem:InvokeServer(item) end)
                    processed[item]=true
                    task.delay(2,function() processed[item]=nil end)
                end
                break
            end
        end
    end
end)

